{
  "name": "scrobbler-for-discogs-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "scrobbler-for-discogs-libs": "file:../libs"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@babel/preset-typescript": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "babel-jest": "^30.0.0",
    "immer": "^11.1.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "moduleNameMapper": {
      "^@libs$": "<rootDir>/../libs/src/index.ts",
      "^@libs/(.*)$": "<rootDir>/../libs/src/$1",
      "^scrobbler-for-discogs-libs$": "<rootDir>/../libs/src/index.ts"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)",
      "**/*.test.ts?(x)"
    ]
  }
}
